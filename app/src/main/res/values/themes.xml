<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AurexScanner" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Corner8" parent="">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Theme.AurexScanner.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Premium Glassy Dialog Style -->
    <style name="PremiumGlassyDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/glassy_dialog_bg</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <!-- Button styles -->
        <item name="buttonBarPositiveButtonStyle">@style/PremiumDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/PremiumDialogButton.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/PremiumDialogButton</item>
    </style>

    <style name="PremiumDialogButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PremiumDialogButton.Negative">
        <item name="android:textColor">#757575</item>
    </style>
</resources>
